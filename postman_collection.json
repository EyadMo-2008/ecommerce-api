{
  "info": {
    "name": "E-Commerce API",
    "description": "Postman collection for Products, Cart, and Orders APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products (with filters)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?category=&minPrice=100&maxPrice=1000&inStock=true&search=laptop",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "category", "value": "" },
                { "key": "minPrice", "value": "100" },
                { "key": "maxPrice", "value": "1000" },
                { "key": "inStock", "value": "true" },
                { "key": "search", "value": "laptop" }
              ]
            }
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/PRODUCT_ID_HERE"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Mouse\",\n  \"description\": \"Ergonomic wireless mouse\",\n  \"price\": 25.99,\n  \"category\": \"CATEGORY_ID_HERE\",\n  \"stock\": 50\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 22.99,\n  \"stock\": 45\n}"
            },
            "url": "{{baseUrl}}/products/PRODUCT_ID_HERE"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/products/PRODUCT_ID_HERE"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/cart/items"
          }
        },
        {
          "name": "Update Item Quantity",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 5\n}"
            },
            "url": "{{baseUrl}}/cart/items/PRODUCT_ID_HERE"
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart/items/PRODUCT_ID_HERE"
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get Order By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/ORDER_ID_HERE"
          }
        },
        {
          "name": "Create Order (Checkout)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"123 Main Street, Cairo, Egypt\"\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shipped\"\n}"
            },
            "url": "{{baseUrl}}/orders/ORDER_ID_HERE/status"
          }
        }
      ]
    }
  ]
}